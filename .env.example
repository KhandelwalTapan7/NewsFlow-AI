# API Keys for News Services
NEWS_API_KEY=your_newsapi_key_here
GUARDIAN_API_KEY=your_guardian_api_key_here
NEWSDATA_IO_API_KEY=your_newsdata_io_api_key_here
WORLD_NEWS_API_KEY=your_world_news_api_key_here

# Redis Connection URL
REDIS_URL=redis://your_redis_host:port

# Model Configuration for Summarization
SUMMARIZATION_MODEL=facebook/bart-large-cnn  # Pre-trained model for summarization
USE_GPU=false                                # Set to true if you want to use GPU for inference
BATCH_SIZE=4                                 # Batch size for model inference
MODEL_CACHE_DIR=./models/cache               # Directory to cache model weights

# Embedding Model for RAG
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2   # Embedding model for RAG (e.g., sentence-transformers)
VECTOR_STORE_TYPE=chromadb                                 # Vector store type for RAG (options: chromadb, pinecone, weaviate)
CHROMA_PERSIST_DIR=./data/chroma_db                        # Directory to store vector data